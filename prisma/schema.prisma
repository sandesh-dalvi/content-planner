
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


// USER - primary key is clerk's user ID
model User {
  id        String   @id
  email     String   @unique
  name      String?
  image      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace?
  posts     Post[]

  @@index([email])
  @@map("users")
}


// WORKSPACE
model Workspace {
id        String   @id @default(cuid())
userId    String   @unique
name      String
slug      String   @unique
createdAt DateTime @default(now())
updatedAt DateTime @updatedAt

user      User     @relation(fields: [userId], references: [id],onDelete: Cascade)
posts     Post[]

@@index([userId])
@@index([slug])
@@map("workspaces")
}


// POST
model Post {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String

// Content
  title       String
  content     Json    @db.JsonB

// Platform & Workflow
  platform    Platform
  status      PostStatus @default(DRAFT)

  // Scheduling
  scheduledFor DateTime?
  publishedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id],onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id],onDelete: Cascade)
  media     Media[]

  // Query indexes
  @@index([workspaceId, status])        // Kanban board: filter by workspace + status
  @@index([workspaceId, scheduledFor])  // Calendar: posts for a date range
  @@index([workspaceId, createdAt])     // List view: recent posts
  @@index([workspaceId, platform])      // Dashboard: posts per platform
  @@index([userId])                     // All posts by a user
  @@index([status, scheduledFor])       // Future: scheduled job processing

  @@map("posts")
}

// MEDIA
model Media {
  id        String   @id @default(cuid())
  postId    String

  url       String
  filename  String
  mimeType  String
  size      Int
  width     Int?
  height    Int?

  uploadedAt DateTime @default(now())

  post      Post     @relation(fields: [postId], references: [id],onDelete: Cascade)

  @@index([postId])
  @@map("media")
}


// ENUMS
enum Platform {
  TWITTER
  LINKEDIN
  FACEBOOK
  INSTAGRAM
  TIKTOK
  YOUTUBE
}

enum PostStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  SCHEDULED
  PUBLISHED
}